menu "DHT11 Config"

    orsource "$IDF_PATH/examples/common_components/env_caps/$IDF_TARGET/Kconfig.env_caps"

    config SENSOR_GPIO
        int "The sensor's GPIO"
        range ENV_GPIO_RANGE_MIN ENV_GPIO_OUT_RANGE_MAX
        default 27

    config POLL_RATE_MS
        int "The rate at which the sensor will poll in ms"
        range 1000 5000
        default 1000

endmenu
